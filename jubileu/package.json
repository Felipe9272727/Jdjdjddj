{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0 <23"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint:eslint": "eslint src/ --ext .ts,.tsx",
    "lint:types": "tsc --noEmit",
    "audit": "node audit.mjs",
    "check": "npm run lint:types && npm run test && npm run audit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "install:locked": "npm ci",
    "build:reproducible": "npm ci && npm run build && node inline-build.mjs"
  },
  "dependencies": {
    "@google/genai": "1.50.1",
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.0",
    "@tailwindcss/vite": "4.2.2",
    "@vitejs/plugin-react": "5.2.0",
    "dotenv": "17.4.2",
    "express": "4.22.1",
    "lucide-react": "0.546.0",
    "motion": "12.38.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "three": "0.184.0",
    "vite": "6.4.2"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@firebase/eslint-plugin-security-rules": "0.0.1",
    "@firebase/rules-unit-testing": "5.0.0",
    "@types/express": "4.17.25",
    "@types/node": "22.19.17",
    "@vitest/coverage-v8": "4.1.5",
    "autoprefixer": "10.5.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.26",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.59.0",
    "vite": "6.4.2",
    "vitest": "4.1.5"
  }
}
